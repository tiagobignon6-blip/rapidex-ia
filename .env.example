# RAPIDEX IA — env profile example
#
# Copy to .env and edit per your runtime. .env is gitignored.
# The same app.py honours these across 3 deploy targets.
#
# Resolution priority for *_DIR vars (see pipeline/runtime.py):
#   1. explicit value below
#   2. legacy /workspace/<name> if it exists on disk (pod no-regression)
#   3. ${RAPIDEX_MODELS_DIR}/<engine> default


# ─────────────────────────────────────────────────────────────────────────────
#  Profile: Local dev — WSL2 + NVIDIA GPU (Compose path)
# ─────────────────────────────────────────────────────────────────────────────
# Use these defaults with `docker compose -f infra/local/docker-compose.yml up`

RAPIDEX_MODELS_DIR=/app/models                # inside container
RAPIDEX_OUTPUTS_DIR=/app/outputs              # mounted to ./outputs on the host
MUSETALK_DIR=/app/models/musetalk
WAV2LIP_DIR=/app/models/wav2lip
FISH_SPEECH_DIR=/app/models/fish-speech
RAPIDEX_DEVICE=cuda                           # cuda / mps / cpu / unset (auto)
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SHARE=false                            # localhost only


# ─────────────────────────────────────────────────────────────────────────────
#  Profile: Local dev — bare WSL2, no Docker (UI iteration / CPU mode)
# ─────────────────────────────────────────────────────────────────────────────
# Uncomment + comment-out the Compose block above when running:
#   RAPIDEX_DEVICE=cpu python app.py

# RAPIDEX_MODELS_DIR=./models
# RAPIDEX_OUTPUTS_DIR=./outputs
# MUSETALK_DIR=./models/musetalk
# WAV2LIP_DIR=./models/wav2lip
# FISH_SPEECH_DIR=./models/fish-speech
# RAPIDEX_DEVICE=cpu                          # UI boots, dub raises gr.Error
# GRADIO_SERVER_NAME=127.0.0.1
# GRADIO_SHARE=false


# ─────────────────────────────────────────────────────────────────────────────
#  Profile: RunPod (legacy /workspace/ layout — pre-swap)
# ─────────────────────────────────────────────────────────────────────────────
# No env file needed on the pod; the legacy paths win via the resolve_dir
# fallback chain. Documented here for completeness.
#
# Effective values after auto-resolution on a pod where /workspace/* exists:
#   MUSETALK_DIR=/workspace/MuseTalk
#   WAV2LIP_DIR=/workspace/Wav2Lip
#   FISH_SPEECH_DIR=/workspace/fish-speech
#   RAPIDEX_OUTPUTS_DIR=/workspace


# ─────────────────────────────────────────────────────────────────────────────
#  Profile: HuggingFace Spaces (Phase 10 — placeholder)
# ─────────────────────────────────────────────────────────────────────────────
# Lands in infra/hfspaces/Dockerfile during Phase 10. Sketch:
#
# RAPIDEX_MODELS_DIR=/data/models             # /data persists across restarts
# RAPIDEX_OUTPUTS_DIR=/tmp/outputs
# HF_HOME=/data/.cache/huggingface            # Pitfall #5 mitigation
# RAPIDEX_DEVICE=cuda
# GRADIO_SERVER_NAME=0.0.0.0
# GRADIO_SHARE=false
# HF_TOKEN=                                   # secret, set in HF Spaces UI
